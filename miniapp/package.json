{
  "name": "timemanager-miniapp",
  "version": "1.0.0",
  "private": true,
  "description": "AI时间管理APP小程序端",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass"
  },
  "scripts": {
    "dev:weapp": "taro build --type weapp --watch",
    "dev:h5": "taro build --type h5 --watch",
    "build:weapp": "taro build --type weapp",
    "build:h5": "taro build --type h5",
    "test": "jest --runInBand --config jest.config.ts",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "browserslist": [
    "last 3 Chrome versions",
    "last 3 Firefox versions",
    "last 3 Opera versions",
    "last 3 Edge versions"
  ],
  "dependencies": {
    "@babel/preset-react": "^7.28.5",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "@tarojs/components": "4.1.11",
    "@tarojs/helper": "^4.1.11",
    "@tarojs/plugin-platform-h5": "4.1.11",
    "@tarojs/plugin-platform-weapp": "4.1.11",
    "@tarojs/react": "4.1.11",
    "@tarojs/runtime": "4.1.11",
    "@tarojs/taro": "4.1.11",
    "ajv": "^8.18.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-refresh": "^0.18.0",
    "webpack": "^5.105.4",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@playwright/test": "^1.58.2",
    "@tarojs/cli": "4.1.11",
    "@tarojs/plugin-framework-react": "4.1.11",
    "@tarojs/webpack5-runner": "4.1.11",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.3.20",
    "babel-jest": "^29.7.0",
    "babel-preset-taro": "4.1.11",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "ts-jest": "^29.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}
